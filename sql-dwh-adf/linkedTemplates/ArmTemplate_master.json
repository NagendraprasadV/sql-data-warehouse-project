{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "sql-dwh-adf"
		},
		"Ls_azure_sql_bronze_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Ls_azure_sql_bronze'"
		},
		"Ls_blob_storage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Ls_blob_storage'"
		},
		"Ls_azure_sql_bronze_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqldwh14.database.windows.net"
		},
		"Ls_azure_sql_bronze_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sql_data_ware_house"
		},
		"Ls_azure_sql_bronze_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "prasad15"
		},
		"tr_on_blob_csv_arrival_properties_pl_live_ingest_parameters_Foldername": {
			"type": "string",
			"defaultValue": "@triggerBody().folderPath"
		},
		"tr_on_blob_csv_arrival_properties_pl_live_ingest_parameters_Filename": {
			"type": "string",
			"defaultValue": "@triggerBody().fileName"
		},
		"tr_on_blob_csv_arrival_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/0bd10967-5ab8-4a0d-a33b-614f58a3e11d/resourceGroups/SQL-DHW-RG/providers/Microsoft.Storage/storageAccounts/sadhingestprod"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "sql-dwh-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Ls_azure_sql_bronze_password": {
						"value": "[parameters('Ls_azure_sql_bronze_password')]"
					},
					"Ls_blob_storage_connectionString": {
						"value": "[parameters('Ls_blob_storage_connectionString')]"
					},
					"Ls_azure_sql_bronze_properties_typeProperties_server": {
						"value": "[parameters('Ls_azure_sql_bronze_properties_typeProperties_server')]"
					},
					"Ls_azure_sql_bronze_properties_typeProperties_database": {
						"value": "[parameters('Ls_azure_sql_bronze_properties_typeProperties_database')]"
					},
					"Ls_azure_sql_bronze_properties_typeProperties_userName": {
						"value": "[parameters('Ls_azure_sql_bronze_properties_typeProperties_userName')]"
					},
					"tr_on_blob_csv_arrival_properties_pl_live_ingest_parameters_Foldername": {
						"value": "[parameters('tr_on_blob_csv_arrival_properties_pl_live_ingest_parameters_Foldername')]"
					},
					"tr_on_blob_csv_arrival_properties_pl_live_ingest_parameters_Filename": {
						"value": "[parameters('tr_on_blob_csv_arrival_properties_pl_live_ingest_parameters_Filename')]"
					},
					"tr_on_blob_csv_arrival_properties_typeProperties_scope": {
						"value": "[parameters('tr_on_blob_csv_arrival_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}