			},
			{
				"name": "cst_lastname",
				"type": "String"
			},
			{
				"name": "cst_marital_status",
				"type": "String"
			},
			{
				"name": "cst_gndr",
				"type": "String"
			},
			{
				"name": "cst_create_date",
				"type": "String"
			}
		]
	},
	"type": "Microsoft.DataFactory/factories/datasets"
